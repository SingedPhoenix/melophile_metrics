{
  "name": "melophile-metrics",
  "productName": "melophile metrics",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first personal music analytics app for Last.fm, Spotify, and MusicBrainz workflows.",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev:renderer": "vite --config vite.config.ts",
    "build:renderer": "vite build --config vite.config.ts",
    "check:renderer": "tsc --noEmit -p tsconfig.renderer.json",
    "build:mac": "scripts/build-macos-app.sh",
    "start:mac": "scripts/build-macos-app.sh && open \"dist/melophile metrics.app\"",
    "start:web": "python3 -m http.server 8767",
    "test:smoke": "npm run build:renderer && playwright test",
    "check:js": "node --check electron/main.js && node --check electron/preload.js && node --check electron/database.js",
    "check": "npm run check:js && npm run check:renderer"
  },
  "build": {
    "appId": "com.singedphoenix.melophilemetrics",
    "productName": "melophile metrics",
    "mac": {
      "icon": "assets/app-icon/melophile-metrics.icns"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
